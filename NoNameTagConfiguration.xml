<?xml version="1.0" encoding="utf-8"?>
<NoNameTagConfiguration xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Enabled>true</Enabled>
  <DebugMode>false</DebugMode>
  <DefaultNameColor>#FFFFFF</DefaultNameColor>
  <ApplyToChatMessages>true</ApplyToChatMessages>
  <PriorityMode>HighestPriority</PriorityMode>

  <PermissionGroups>
    <PermissionGroup permission="nonametag.vip" priority="10">
      <DisplayEffect>
        <Prefix>[VIP] </Prefix>
        <PrefixColor>#FFD700</PrefixColor>
        <NameColor>green</NameColor>
        <Suffix></Suffix>
        <SuffixColor>#FFFFFF</SuffixColor>
      </DisplayEffect>
    </PermissionGroup>
    <PermissionGroup permission="nonametag.mvp" priority="20">
      <DisplayEffect>
        <Prefix>[MVP] </Prefix>
        <PrefixColor>yellow</PrefixColor>
        <NameColor>#00BFFF</NameColor>
        <Suffix> *</Suffix>
        <SuffixColor>yellow</SuffixColor>
      </DisplayEffect>
    </PermissionGroup>
  </PermissionGroups>

  <DeathMessage>
    <Enabled>true</Enabled>
    <DisplayMode>Chat</DisplayMode>
    <Visibility>All</Visibility>
    <FontColor></FontColor>
    <FontSize>0</FontSize>
    <Format>{killer} 击杀了 {victim}</Format>
    <SelfKillFormat>{victim} 自杀了</SelfKillFormat>
    <BleedingFormat>{victim} 流血致死</BleedingFormat>
    <ZombieFormat>{victim} 被僵尸击杀</ZombieFormat>
    <AnimalFormat>{victim} 被动物击杀</AnimalFormat>
    <VehicleFormat>{victim} 死于车祸</VehicleFormat>
    <FallFormat>{victim} 摔死了</FallFormat>
    <DrownFormat>{victim} 淹死了</DrownFormat>
    <FreezeFormat>{victim} 冻死了</FreezeFormat>
    <BurnFormat>{victim} 被烧死了</BurnFormat>
    <FoodFormat>{victim} 饿死了</FoodFormat>
    <WaterFormat>{victim} 渴死了</WaterFormat>
    <InfectionFormat>{victim} 感染致死</InfectionFormat>
    <GunFormat>{victim} 被 {killer} 射杀</GunFormat>
    <MeleeFormat>{victim} 被 {killer} 砍死</MeleeFormat>
    <PunchFormat>{victim} 被 {killer} 打死</PunchFormat>
    <GrenadeFormat>{victim} 被 {killer} 炸死</GrenadeFormat>
    <HeadshotTag> [爆头]</HeadshotTag>
    <DefaultFormat>{victim} 死亡了</DefaultFormat>
  </DeathMessage>

  <BroadcastGroups>
    <BroadcastGroup name="server_tips" enabled="true" displayMode="Chat">
      <RotationInterval>300</RotationInterval>
      <Messages>
        <Message>
          <Message>欢迎来到服务器！请遵守规则。</Message>
          <FontColor>white</FontColor>
          <FontSize>0</FontSize>
          <Avatar>{server_icon}</Avatar>
          <AvatarPosition>Left</AvatarPosition>
        </Message>
        <Message>
          <Message>使用 /help 查看可用命令。</Message>
          <FontColor>#FFFF00</FontColor>
          <FontSize>0</FontSize>
          <Avatar>{server_icon}</Avatar>
          <AvatarPosition>Left</AvatarPosition>
        </Message>
      </Messages>
    </BroadcastGroup>
  </BroadcastGroups>

  <WelcomeMessage enabled="true">
    <Text>欢迎 {player} 加入服务器！</Text>
    <IconUrl>{server_icon}</IconUrl>
    <Color>white</Color>
    <FontSize>0</FontSize>
    <EnableJoinLink>false</EnableJoinLink>
    <JoinLinkUrl></JoinLinkUrl>
    <JoinLinkMessage></JoinLinkMessage>
    <EnableLeaveMessage>true</EnableLeaveMessage>
    <LeaveText>{player} 离开了服务器</LeaveText>
    <LeaveIconUrl>{server_icon}</LeaveIconUrl>
    <LeaveColor>white</LeaveColor>
    <LeaveFontSize>0</LeaveFontSize>
  </WelcomeMessage>

  <StatsSettings>
    <Enabled>true</Enabled>
    <DatabaseRelativePath>Data/nonametag.litedb</DatabaseRelativePath>
    <CommandTimeoutSeconds>5</CommandTimeoutSeconds>
    <ShowInFormattedNames>true</ShowInFormattedNames>
    <DisplayFormat> [KS:{streak} K:{kills} D:{deaths}]</DisplayFormat>
    <DisplayColor>#C0C0C0</DisplayColor>
    <DisplayFontSize>0</DisplayFontSize>
    <BleedHitRetentionSeconds>15</BleedHitRetentionSeconds>
    <BleedSourceRetentionSeconds>180</BleedSourceRetentionSeconds>
  </StatsSettings>

  <TextCommands>
    <TextCommand>
      <Name>rules</Name>
      <Message>请遵守服务器规则！</Message>
      <IconUrl>{server_icon}</IconUrl>
      <Color>white</Color>
    </TextCommand>
  </TextCommands>

  <WebCommands>
    <WebCommand>
      <Name>website</Name>
      <Url>https://example.com</Url>
      <Description>访问我们的网站</Description>
    </WebCommand>
  </WebCommands>
</NoNameTagConfiguration>
